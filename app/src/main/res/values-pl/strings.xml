	<string name="info_format"><b>M4a</b> to format zakodowany z kodekiem audio AAC o dobrej jakości i małym rozmiarze. <b>(zalecane)</b>
		\n<b>Wav</b> to nieskompresowany format danych audio. Zajmuje znacznie więcej miejsca niż inne formaty. Potrzebny w szczególnych przypadkach.
		\n<b>3gp</b> to format kontenera multimedialnego opracowany dla mobilnych usług telekomunikacyjnych. Użyj go, jeśli potrzebujesz zaoszczędzić miejsce.
		</string>

	<string name="info_format_html"><![CDATA[
<b>M4a</b> to format zakodowany z kodekiem audio AAC o dobrej jakości i małym rozmiarze. <b>(zalecane)</b>
<br/><br/><b>Wav</b> to nieskompresowany format danych audio. Zajmuje znacznie więcej miejsca niż inne formaty. Potrzebny w szczególnych przypadkach.
<br/><b>3gp</b> to format kontenera multimedialnego opracowany dla mobilnych usług telekomunikacyjnych. Użyj go, jeśli potrzebujesz zaoszczędzić miejsce.
]]></string>

	<string name="info_frequency"><b>Częstotliwość próbkowania</b> to liczba próbek audio przesyłanych na sekundę.
		\n<b>48 kHz</b> to częstotliwość próbkowania używana dla DVD.
		\n<b>44,1 kHz</b> to częstotliwość próbkowania płyt Audio CD. <b>(zalecane)</b>
		\n<b>22 kHz</b> — popularna częstotliwość dla niskich przepływności, np. 64 kbps.
		\n <b>8 kHz</b> — przepustowość mniejsza niż we współczesnych systemach telefonicznych. Nieodpowiednia do żadnych poważnych zadań nagraniowych.
		</string>

	<string name="info_frequency_html"><![CDATA[
<b>Częstotliwość próbkowania</b> to liczba próbek audio przesyłanych na sekundę.
<br/><br/><b>48 kHz</b> to częstotliwość próbkowania używana dla DVD.
<br/><b>44,1 kHz</b> to częstotliwość próbkowania płyt Audio CD. <b>(zalecane)</b>
<br/><b>22 kHz</b> — popularna częstotliwość dla niskich przepływności, np. 64 kbps.
<br/><b>8 kHz</b> — przepustowość mniejsza niż we współczesnych systemach telefonicznych. Nieodpowiednia do żadnych poważnych zadań nagraniowych.
]]></string>

	<string name="info_bitrate"><b>Bitrate</b> to ilość danych na sekundę dźwięku. Bezpośrednio wpływa na jakość i rozmiar nagrania.
		\n<b>256 kbps</b> — bitrate dobrej jakości.
		\n<b>192 kbps</b> — bitrate średniej jakości.
		\n<b>128 kbps</b> — bitrate jakości średniego zakresu. Popularny bitrate dla podcastów. <b>(zalecane)</b>
		\n<b>96 kbps</b> — zazwyczaj używany do mowy lub strumieniowania niskiej jakości.
		\n<b>48 kbps</b> — ogólnie akceptowalny jedynie dla mowy.
		</string>

    <string name="info_bitrate_html"><![CDATA[
<b>Bitrate</b> to ilość danych na sekundę dźwięku. Bezpośrednio wpływa na jakość i rozmiar nagrania.
<br/><br/><b>256 kbps</b> — bitrate dobrej jakości.
<br/><b>192 kbps</b> — bitrate średniej jakości.
<br/><b>128 kbps</b> — bitrate jakości średniego zakresu. Popularny bitrate dla podcastów. <b>(zalecane)</b>
<br/><b>96 kbps</b> — zazwyczaj używany do mowy lub strumieniowania niskiej jakości.
<br/><b>48 kbps</b> — ogólnie akceptowalny jedynie dla mowy.
]]></string>

	<string name="info_channels">
		<b>Stereo</b> — nagrywane są dwa oddzielne kanały. Każdy głośnik stereo odtwarza inny sygnał dźwiękowy. <b>(zalecane)</b>
		\n<b>Mono</b> — nagrywany jest jeden kanał sygnału. Może być odtwarzany przez kilka głośników, ale wszystkie odtwarzają tę samą kopię sygnału.
		</string>

    <string name="info_channels_html"><![CDATA[
<b>Stereo (dwukanałowy):</b> Nagrywa dwa niezależne kanały audio, tworząc poczucie przestrzeni i kierunkowości. <b>(zalecane)</b>
<br/><br/><b>Mono (jednokanałowy):</b> Nagrywa jeden kanał audio. Ten sam sygnał jest odtwarzany przez wszystkie głośniki.
]]></string>

    <string name="info_audio_source_html"><![CDATA[
<b>Domyślne:</b> Ustawienie zalecane przez producenta. Zazwyczaj działa jak opcja <b>Mikrofon</b>, ale pozwala urządzeniu zastosować własne zoptymalizowane ustawienia sprzętowe.
<br/><br/><b>Mikrofon:</b> Standardowe ustawienie mikrofonu. Najlepsze do nagrywania ogólnego. Automatycznie balansuje głośność głosu, zachowując naturalną atmosferę otoczenia.
<br/><br/><b>Komunikacja głosowa:</b> Zaprojektowane specjalnie dla wyrazistości ludzkiego głosu. Najlepsze dla Bluetooth — aktywuje redukcję szumów i echa.
<br/><br/><b>Bez przetwarzania:</b> Rejestruje surowe audio bez żadnych filtrów ani regulacji systemowych. Brak redukcji szumów tła i wyrównywania głośności. Najlepsze do nagrań wysokiej wierności lub zastosowań profesjonalnych.
]]></string>
	<string name="info_3gp"><b>3gp</b> to format kontenera multimedialnego opracowany dla mobilnych usług telekomunikacyjnych. Użyj go, jeśli potrzebujesz zaoszczędzić miejsce.</string>
	<string name="info_m4a"><b>M4a</b> to format zakodowany z kodekiem audio AAC o dobrej jakości i małym rozmiarze. <b>(zalecane)</b></string>
	<string name="info_wav"><b>Wav</b> to nieskompresowany format danych audio. Zajmuje znacznie więcej miejsca niż inne formaty. Potrzebny w szczególnych przypadkach.</string>
	<string name="info_stereo"><b>Stereo</b> — nagrywane są dwa oddzielne kanały. Każdy głośnik stereo odtwarza inny sygnał dźwiękowy. <b>(zalecane)</b></string>
	<string name="info_mono"><b>Mono</b> — nagrywany jest jeden kanał sygnału. Może być odtwarzany przez kilka głośników, ale wszystkie odtwarzają tę samą kopię sygnału.</string>
	<string name="info_bitrate_48"><b>48 kbps</b> — ogólnie akceptowalny jedynie dla mowy.</string>
	<string name="info_bitrate_96"><b>96 kbps</b> — zazwyczaj używany do mowy lub strumieniowania niskiej jakości.</string>
	<string name="info_bitrate_128"><b>128 kbps</b> — bitrate jakości średniego zakresu. Popularny bitrate dla podcastów. <b>(zalecane)</b></string>
	<string name="info_bitrate_192"><b>192 kbps</b> — bitrate średniej jakości.</string>
	<string name="info_bitrate_256"><b>256 kbps</b> — bitrate dobrej jakości.</string>
	<string name="info_bitrate_288"><b>288 kbps</b> — bitrate bardzo wysokiej jakości.</string>
	<string name="info_sample_rate_8k"><b>8 kHz</b> — przepustowość mniejsza niż we współczesnych systemach telefonicznych. Nieodpowiednia do żadnych poważnych zadań nagraniowych.</string>
	<string name="info_sample_rate_16k"><b>16 kHz</b> — lepsza niż 8 kHz.</string>
	<string name="info_sample_rate_22k"><b>22 kHz</b> — popularna częstotliwość dla niskich przepływności, np. 64 kbps.</string>
	<string name="info_sample_rate_32k"><b>32 kHz</b> — nieco lepsza niż 22 kHz.</string>
	<string name="info_sample_rate_44k"><b>44,1 kHz</b> to częstotliwość próbkowania płyt Audio CD. <b>(zalecane)</b></string>
	<string name="info_sample_rate_48k"><b>48 kHz</b> to częstotliwość próbkowania używana dla DVD.</string>
